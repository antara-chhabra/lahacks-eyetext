INTENT_AGENT_MAILBOX_KEY=your_intent_agent_key_here
MEMORY_AGENT_MAILBOX_KEY=your_memory_agent_key_here
EMOTIONAL_AGENT_MAILBOX_KEY=your_emotional_agent_key_here
OUTPUT_AGENT_MAILBOX_KEY=your_output_agent_key_here
ROUTER_AGENT_MAILBOX_KEY=your_router_agent_key_here

# ── Agent seeds (deterministic — do not change or agent addresses will rotate) ─
