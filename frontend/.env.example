# Your Cloudinary cloud name — find it at https://console.cloudinary.com/
VITE_CLOUDINARY_CLOUD_NAME=

# Optional: unsigned upload preset for the Upload Widget
VITE_CLOUDINARY_UPLOAD_PRESET=

# Agent gateway (Task 2)
VITE_AGENT_URL=http://localhost:8000

# Backend REST API (Task 4)
VITE_BACKEND_URL=http://localhost:3001

# Demo patient ID (populated by backend seed script)
VITE_DEMO_USER_ID=demo-1
